{
  "name": "delta",
  "category": "git",
  "install_method": "auto",
  "description": "A syntax-highlighting pager for git, diff, and grep output",
  "homepage": "https://github.com/dandavison/delta",
  "github_repo": "dandavison/delta",
  "binary_name": "delta",
  "download_url_template": "https://github.com/dandavison/delta/releases/download/{version}/delta-{version}-{arch}-unknown-linux-musl.tar.gz",
  "arch_map": {
    "x86_64": "x86_64",
    "aarch64": "aarch64",
    "armv7l": "armv7"
  },
  "available_methods": [
    {
      "method": "github_release_binary",
      "priority": 1,
      "config": {
        "repo": "dandavison/delta",
        "asset_pattern": "delta-.*-x86_64-unknown-linux-musl.tar.gz"
      }
    },
    {
      "method": "cargo",
      "priority": 2,
      "config": {
        "crate": "git-delta"
      }
    },
    {
      "method": "apt",
      "priority": 3,
      "config": {
        "package": "git-delta"
      }
    }
  ],
  "tags": [
    "core"
  ]
}
